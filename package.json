{
  "name": "amebic",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev": "bun run --filter @amebic/preview dev",
    "test": "bun run --filter '@amebic/core' test && bun run --filter '@amebic/templates' test && bun run --filter '@amebic/examples' test",
    "render": "bun run packages/cli/dist/cli.js render",
    "list": "bun run packages/cli/dist/cli.js list",
    "render:branding": "bun run render AmebicBranding --set --out-dir ./branding/output"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
